# =====================================
# 1000 Mains et Merveilles - Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# =====================================

# Environnement : development | staging | production
APP_ENV=production

# Base de données
DB_HOST=db
DB_PORT=3306
DB_NAME=1000mains
DB_USER=1000mains
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# MySQL root (utilisé par le conteneur db)
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
